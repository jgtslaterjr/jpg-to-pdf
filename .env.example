# Copy this file to .env and adjust as needed.
# OCR uses Tesseract by default — no API key is required.

# Optional: change the OCR language (default: eng). Examples: eng, fra, deu,
# spa, eng+fra. The trained-data file is downloaded once and cached in
# .tessdata/.
OCR_LANG=eng

# Optional: HTTP port
PORT=3000

# The Anthropic API key is no longer used for OCR, but is kept here for
# possible future text post-processing features.
# ANTHROPIC_API_KEY=
